# ==========================================
# NEXT.JS WEB PROJECT - CONFIGURATION
# ==========================================

OUTPUT_FILE="a.txt"

# Prioritize core Next.js directories
INCLUDE_PATHS=(
    "./app"
    "./components"
    "./lib"
    "./types"
)

PRUNE_EXCEPTIONS=(
)

# Exclude build artifacts, media, and lock files
WEB_PRUNES=(
    "./node_modules"
    "./.next"
    "./out"
    "./dist"
    "./.git"
    "./.idea"
    "./.vscode"
    "./coverage"
    "./.venv"
    ".eslintcache"
    "*.tsbuildinfo"

    # --- EXCLUDE TESTS BY DEFAULT ---
    "./tests/e2e"
    "*.wtr.test.ts"
    "*.test.ts"
    
    # --- EXCLUDE HEAVY MOCK DATA ---
    "./current_response.json"
    "./bedrock-6d04a-firebase-adminsdk-fbsvc-38ae97cff1.json"

    # --- Exclude Images & Media ---
    "*.png"
    "*.jpg"
    "*.jpeg"
    "*.gif"
    "*.svg"
    "*.ico"
    "*.webp"
    "*.mp4"
    "*.mov"
    "*.pdf"

    # --- Exclude Test Artifacts ---
    "./test-results"
    "./playwright-report"

    # --- Exclude Infrastructure Binaries ---
    "./infra/hetzner/.terraform"
    "*.tfstate"
    "*.tfstate.backup"

    # --- Exclude Native Platforms ---
    "./android"
    "./ios"

    # --- Exclude Lock Files and Binaries ---
    "./bun.lock"
    "./bun.lockb"
    "./package-lock.json"
    "./pnpm-lock.yaml"
    "./yarn.lock"
)

# Grab configuration files at the root level
ROOT_EXTENSIONS=(
    "*.json"
    "*.ts"
    "*.mjs"
    "*.js"
    "*.md"
    "*.sh"
    "*.py"
)

ROOT_EXCLUDES=(
    "package-lock.json"
    "pnpm-lock.yaml"
    "tsconfig.tsbuildinfo"
)
